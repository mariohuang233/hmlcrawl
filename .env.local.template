# ========== 告警通知配置（选择一种或多种） ==========

# 1. 企业微信机器人（推荐）
# 在企业微信群中添加机器人，获取Webhook地址
# WECHAT_WEBHOOK_URL=https://qyapi.weixin.qq.com/cgi-bin/webhook/send?key=your-webhook-key

# 2. Server酱微信推送（推荐）
# 注册地址: https://sct.ftqq.com/
# 获取SendKey后填入
# SERVER_CHAN_KEY=your-send-key

# 3. 邮件通知
# 支持QQ邮箱、163邮箱、企业邮箱等
# EMAIL_HOST=smtp.qq.com
# EMAIL_PORT=465
# EMAIL_USER=your-email@qq.com
# EMAIL_PASS=your-email-password-or-app-password
# EMAIL_TO=recipient@example.com

# 4. Telegram 告警配置
# TELEGRAM_BOT_TOKEN=your-bot-token
# TELEGRAM_CHAT_ID=your-chat-id

# 告警级别: error | warn | info（默认: warn）
# ALERT_LEVEL=warn

# 电量告警配置（可选）
# 当剩余电量低于此值时发送告警通知（单位：kWh）
# BATTERY_ALERT_THRESHOLD=1
# 告警冷却时间（小时），避免频繁发送告警
# BATTERY_ALERT_COOLDOWN_HOURS=4

# 云端后端地址（iPad爬虫上报目标，多个用逗号分隔）
# BACKEND_URL=https://your-app.up.railway.app/api/report
# BACKEND_URLS=https://railway.app/api/report,https://zeabur.app/api/report
