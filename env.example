# MongoDB连接字符串
MONGO_URI=mongodb+srv://mariohuang:<Huangjw1014>@yierbubu.aha67vc.mongodb.net/electricity?retryWrites=true&w=majority&appName=yierbubu

# 服务器端口
PORT=3000

# 爬虫配置
CRAWLER_URL=https://your-electricity-website.com
CRAWLER_INTERVAL=*/10 * * * *

# 云端部署标识（系统自动检测，无需手动设置）
# Railway: RAILWAY_SERVICE_NAME, RAILWAY_STATIC_URL
# Zeabur:  ZEABUR_SERVICE_NAME, ZEABUR_DOMAIN
# 在 Railway/Zeabur 上部署时，系统会自动启用云端保障爬虫

# 云端保障爬虫配置（可选）
# 云端爬虫间隔为每30分钟一次，本地爬虫每15分钟一次
# 两者相互独立，共享同一 MongoDB，互为备份

# 手动控制爬虫（仅在本地部署时有效）
# 设为 true 强制启用，false 禁用
# 云端部署时此选项被忽略（始终启用保障爬虫）
# ENABLE_CRAWLER=true

# 日志级别
LOG_LEVEL=info

# 电表ID
# METER_ID=18100071580

# 电表名称
# METER_NAME=2759弄18号402阳台
